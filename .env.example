# Copy this file to .env for local development.

# Firebase project-level config
FIREBASE_PROJECT_NUMBER=YOUR_PROJECT_NUMBER
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase app / platform config
FIREBASE_ANDROID_APP_ID=YOUR_ANDROID_APP_ID
FIREBASE_ANDROID_PACKAGE_NAME=com.example.artflow_flutter
FIREBASE_ANDROID_API_KEY=YOUR_ANDROID_API_KEY
FIREBASE_ANDROID_OAUTH_CLIENT_ID=YOUR_ANDROID_OAUTH_CLIENT_ID

FIREBASE_IOS_APP_ID=YOUR_IOS_APP_ID
FIREBASE_IOS_BUNDLE_ID=com.example.artflowFlutter
FIREBASE_IOS_API_KEY=YOUR_IOS_API_KEY
FIREBASE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID
FIREBASE_IOS_GOOGLE_APP_ID=YOUR_IOS_GOOGLE_APP_ID

FIREBASE_WEB_APP_ID=YOUR_WEB_APP_ID
FIREBASE_WEB_API_KEY=YOUR_WEB_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firestore / Realtime Database references
FIRESTORE_USERS_COLLECTION=users
FIRESTORE_ARTWORKS_COLLECTION=artworks
FIRESTORE_BIDS_COLLECTION=bids
FIRESTORE_COMMISSIONS_COLLECTION=commissions
FIRESTORE_TRANSACTIONS_COLLECTION=transactions
FIRESTORE_DISPUTES_COLLECTION=disputes
FIRESTORE_PLATFORM_SETTINGS_COLLECTION=platformSettings
FIRESTORE_ARTIST_APPLICATIONS_COLLECTION=artistApplications
RTDB_PRESENCE_REF=/presence
RTDB_CHAT_REF=/chat
RTDB_NOTIFICATIONS_REF=/notifications

# Optional emulator/dev settings
USE_FIREBASE_EMULATORS=false
FIRESTORE_EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080
FIREBASE_AUTH_EMULATOR_HOST=localhost
FIREBASE_AUTH_EMULATOR_PORT=9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost
FIREBASE_STORAGE_EMULATOR_PORT=9199
FIREBASE_DATABASE_EMULATOR_HOST=localhost
FIREBASE_DATABASE_EMULATOR_PORT=9000

# Supabase image upload config
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_STORAGE_BUCKET=artflow-media
SUPABASE_PROFILE_FOLDER=profiles
SUPABASE_ARTWORK_FOLDER=artworks
SUPABASE_ARTIST_APPLICATION_FOLDER=artist-applications
SUPABASE_SCHOLAR_FOLDER=scholar-verifications
